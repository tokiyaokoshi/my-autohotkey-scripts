#Requires AutoHotkey v2.0
#SingleInstance Force  ; スクリプトの重複起動を防ぎ、常駐させます

; ==========================================
; 1. 選択したファイルのパスをテキストとしてコピー
; トリガー：Ctrl + Windows + C
; ==========================================
^#c:: {
    ; クリップボードを一旦空にする
    A_Clipboard := ""
    
    ; 選択中のファイルをコピー（Ctrl + C）
    Send("^c")
    
    ; クリップボードにデータが入るのを待機（最大1秒）
    if ClipWait(1) {
        ; コピーされた「ファイル自体」のデータを、「ファイルのパス（文字列）」に純粋なテキストとして変換する
        A_Clipboard := A_Clipboard
    }
}

; ==========================================
; 2. 書式なしでテキストのみ貼り付け
; トリガー：Ctrl + Windows + V
; ==========================================
^#v:: {
    ; クリップボードの中身をそのまま入れ直し、テキスト形式に変換（書式をリセット）
    A_Clipboard := A_Clipboard
    
    ; パソコンの処理が追いつくように一瞬待機
    Sleep(50)
    
    ; 貼り付け（Ctrl + V）を実行
    Send("^v")
}